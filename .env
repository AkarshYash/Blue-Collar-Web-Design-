# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── LLM ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# Using sqlite by default for local development since PostgreSQL might not be running
DATABASE_URL=sqlite+aiosqlite:///chatbot.db

# ── Redis ────────────────────────────────────────────────────────────────────
# Disable redis locally if you don't have it, or use localhost
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_local_dev_key

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,*
